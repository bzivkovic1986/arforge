@startuml
title Interface / Contract View
top to bottom direction
skinparam shadowing false
skinparam class {
  BackgroundColor White
  ArrowColor #555555
  BorderColor #555555
}

{% for layer in view.layers %}
together {
{% for entity in layer.entities %}
{% if entity.shape == "enum" %}
enum "{{ entity.name }}" as {{ entity.id }} {
  kind: {{ entity.stereotype }}
{% else %}
class "{{ entity.name }}" as {{ entity.id }} {
  kind: {{ entity.stereotype }}
{% endif %}
{% for line in entity.body_lines %}
  {{ line }}
{% endfor %}
}
{% endfor %}
}
{% endfor %}

{% for layer in view.layers[:-1] %}
{{ layer.entities[0].id }} -[hidden]down-> {{ view.layers[loop.index].entities[0].id }}
{% endfor %}

{% for relation in view.relations %}
{{ relation.source_id }} --> {{ relation.target_id }} : {{ relation.label }}
{% endfor %}
@enduml
