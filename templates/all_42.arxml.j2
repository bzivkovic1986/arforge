<?xml version="1.0" encoding="UTF-8"?>
<AUTOSAR xmlns="http://autosar.org/schema/r4.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://autosar.org/schema/r4.0 AUTOSAR_4-2-2.xsd">
  <AR-PACKAGES>
    <AR-PACKAGE>
      <SHORT-NAME>{{ root_pkg }}</SHORT-NAME>
      <AR-PACKAGES>

        <AR-PACKAGE>
          <SHORT-NAME>BaseTypes</SHORT-NAME>
          <ELEMENTS>
            {% for dt in base_types %}
            <SW-BASE-TYPE>
              <SHORT-NAME>{{ dt.name }}</SHORT-NAME>
              {% if dt.bitLength is not none %}
              <BASE-TYPE-SIZE>{{ dt.bitLength }}</BASE-TYPE-SIZE>
              {% endif %}
              {% if dt.signedness == "signed" %}
              <BASE-TYPE-ENCODING>2C</BASE-TYPE-ENCODING>
              {% elif dt.signedness == "unsigned" %}
              <BASE-TYPE-ENCODING>NONE</BASE-TYPE-ENCODING>
              {% endif %}
              {% if dt.nativeDeclaration %}
              <NATIVE-DECLARATION>{{ dt.nativeDeclaration }}</NATIVE-DECLARATION>
              {% endif %}
            </SW-BASE-TYPE>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>ImplementationDataTypes</SHORT-NAME>
          <ELEMENTS>
            {% for dt in implementation_types %}
            <IMPLEMENTATION-DATA-TYPE>
              <SHORT-NAME>{{ dt.name }}</SHORT-NAME>
              {% if dt.is_struct %}
              <CATEGORY>STRUCTURE</CATEGORY>
              <SUB-ELEMENTS>
                {% for f in dt.fields %}
                <IMPLEMENTATION-DATA-TYPE-ELEMENT>
                  <SHORT-NAME>{{ f.name }}</SHORT-NAME>
                  {% set tref = type_trefs.get(f.typeRef) %}
                  <TYPE-TREF DEST="{{ tref.dest if tref else 'IMPLEMENTATION-DATA-TYPE' }}">/{{ root_pkg }}/{{ tref.package if tref else 'ImplementationDataTypes' }}/{{ f.typeRef }}</TYPE-TREF>
                </IMPLEMENTATION-DATA-TYPE-ELEMENT>
                {% endfor %}
              </SUB-ELEMENTS>
              {% else %}
              <CATEGORY>TYPE_REFERENCE</CATEGORY>
              {% endif %}
            </IMPLEMENTATION-DATA-TYPE>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>ApplicationDataTypes</SHORT-NAME>
          <ELEMENTS>
            {% for dt in application_types %}
            <APPLICATION-PRIMITIVE-DATA-TYPE>
              <SHORT-NAME>{{ dt.name }}</SHORT-NAME>
              {% if dt.constraint %}
              <DATA-CONSTR-REF DEST="DATA-CONSTR">/{{ root_pkg }}/DataConstrs/DC_{{ dt.name }}</DATA-CONSTR-REF>
              {% endif %}
              {% if dt.unitRef %}
              <UNIT-REF DEST="UNIT">/{{ root_pkg }}/Units/{{ dt.unitRef }}</UNIT-REF>
              {% endif %}
              {% if dt.compuMethodRef %}
              <COMPU-METHOD-REF DEST="COMPU-METHOD">/{{ root_pkg }}/CompuMethods/{{ dt.compuMethodRef }}</COMPU-METHOD-REF>
              {% endif %}
            </APPLICATION-PRIMITIVE-DATA-TYPE>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>DataConstrs</SHORT-NAME>
          <ELEMENTS>
            {% for dt in application_types if dt.constraint %}
            <DATA-CONSTR>
              <SHORT-NAME>DC_{{ dt.name }}</SHORT-NAME>
              <DATA-CONSTR-RULES>
                <DATA-CONSTR-RULE>
                  <INTERNAL-CONSTRS>
                    <LOWER-LIMIT INTERVAL-TYPE="CLOSED">{{ dt.constraint.min }}</LOWER-LIMIT>
                    <UPPER-LIMIT INTERVAL-TYPE="CLOSED">{{ dt.constraint.max }}</UPPER-LIMIT>
                  </INTERNAL-CONSTRS>
                </DATA-CONSTR-RULE>
              </DATA-CONSTR-RULES>
            </DATA-CONSTR>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>Units</SHORT-NAME>
          <ELEMENTS>
            {% for u in units %}
            <UNIT>
              <SHORT-NAME>{{ u.name }}</SHORT-NAME>
              {% if u.displayName %}
              <DISPLAY-NAME>{{ u.displayName }}</DISPLAY-NAME>
              {% endif %}
            </UNIT>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>CompuMethods</SHORT-NAME>
          <ELEMENTS>
            {% for c in compu_methods %}
            <COMPU-METHOD>
              <SHORT-NAME>{{ c.name }}</SHORT-NAME>
              <CATEGORY>{{ c.category }}</CATEGORY>
              {% if c.category == "linear" %}
              <UNIT-REF DEST="UNIT">/{{ root_pkg }}/Units/{{ c.unitRef }}</UNIT-REF>
              <FACTOR>{{ c.factor }}</FACTOR>
              <OFFSET>{{ c.offset }}</OFFSET>
              {% if c.physMin is not none %}
              <PHYS-MIN>{{ c.physMin }}</PHYS-MIN>
              {% endif %}
              {% if c.physMax is not none %}
              <PHYS-MAX>{{ c.physMax }}</PHYS-MAX>
              {% endif %}
              {% elif c.category == "textTable" %}
              <COMPU-INTERNAL-TO-PHYS>
                <COMPU-SCALES>
                  {% for entry in c.entries %}
                  <COMPU-SCALE>
                    <LOWER-LIMIT>{{ entry.value }}</LOWER-LIMIT>
                    <UPPER-LIMIT>{{ entry.value }}</UPPER-LIMIT>
                    <COMPU-CONST>
                      <VT>{{ entry.label }}</VT>
                    </COMPU-CONST>
                  </COMPU-SCALE>
                  {% endfor %}
                </COMPU-SCALES>
              </COMPU-INTERNAL-TO-PHYS>
              {% endif %}
            </COMPU-METHOD>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>Interfaces</SHORT-NAME>
          <ELEMENTS>

            {% for itf in sr_interfaces %}
            <SENDER-RECEIVER-INTERFACE>
              <SHORT-NAME>{{ itf.name }}</SHORT-NAME>
              <DATA-ELEMENTS>
                {% for de in itf.dataElements %}
                <VARIABLE-DATA-PROTOTYPE>
                  <SHORT-NAME>{{ de.name }}</SHORT-NAME>
                  {% set tref = type_trefs.get(de.typeRef) %}
                  <TYPE-TREF DEST="{{ tref.dest if tref else 'IMPLEMENTATION-DATA-TYPE' }}">/{{ root_pkg }}/{{ tref.package if tref else 'ImplementationDataTypes' }}/{{ de.typeRef }}</TYPE-TREF>
                </VARIABLE-DATA-PROTOTYPE>
                {% endfor %}
              </DATA-ELEMENTS>
            </SENDER-RECEIVER-INTERFACE>
            {% endfor %}

            {% for itf in cs_interfaces %}
            <CLIENT-SERVER-INTERFACE>
              <SHORT-NAME>{{ itf.name }}</SHORT-NAME>
              <OPERATIONS>
                {% for op in itf.operations %}
                <CLIENT-SERVER-OPERATION>
                  <SHORT-NAME>{{ op.name }}</SHORT-NAME>
                </CLIENT-SERVER-OPERATION>
                {% endfor %}
              </OPERATIONS>
            </CLIENT-SERVER-INTERFACE>
            {% endfor %}

          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>Components</SHORT-NAME>
          <ELEMENTS>
            {% for swc in swcs %}
            <APPLICATION-SW-COMPONENT-TYPE>
              <SHORT-NAME>{{ swc.name }}</SHORT-NAME>

              <PORTS>
                {% for p in swc.ports %}
                  {% if p.direction == "provides" %}
                <P-PORT-PROTOTYPE>
                  <SHORT-NAME>{{ p.name }}</SHORT-NAME>
                  {% if p.interfaceType == "senderReceiver" %}
                  <PROVIDED-INTERFACE-TREF DEST="SENDER-RECEIVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</PROVIDED-INTERFACE-TREF>
                  {% else %}
                  <PROVIDED-INTERFACE-TREF DEST="CLIENT-SERVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</PROVIDED-INTERFACE-TREF>
                  {% endif %}
                </P-PORT-PROTOTYPE>
                  {% else %}
                <R-PORT-PROTOTYPE>
                  <SHORT-NAME>{{ p.name }}</SHORT-NAME>
                  {% if p.interfaceType == "senderReceiver" %}
                  <REQUIRED-INTERFACE-TREF DEST="SENDER-RECEIVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</REQUIRED-INTERFACE-TREF>
                  {% else %}
                  <REQUIRED-INTERFACE-TREF DEST="CLIENT-SERVER-INTERFACE">/{{ root_pkg }}/Interfaces/{{ p.interfaceRef }}</REQUIRED-INTERFACE-TREF>
                  {% endif %}
                </R-PORT-PROTOTYPE>
                  {% endif %}
                {% endfor %}
              </PORTS>

              <INTERNAL-BEHAVIORS>
                <SWC-INTERNAL-BEHAVIOR>
                  <SHORT-NAME>IB_{{ swc.name }}</SHORT-NAME>

                  <RUNNABLES>
                    {% for r in swc.runnables %}
                    <RUNNABLE-ENTITY>
                      <SHORT-NAME>{{ r.name }}</SHORT-NAME>
                      <CAN-BE-INVOKED-CONCURRENTLY>false</CAN-BE-INVOKED-CONCURRENTLY>
                      {% if r.reads %}
                      <DATA-RECEIVE-POINT-BY-ARGUMENTS>
                        {% for read in r.reads %}
                        <VARIABLE-ACCESS>
                          <SHORT-NAME>DRP_{{ read.port }}_{{ read.dataElement }}</SHORT-NAME>
                          <ACCESSED-VARIABLE>
                            <AUTOSAR-VARIABLE-IREF>
                              <PORT-PROTOTYPE-REF DEST="R-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ swc.name }}/{{ read.port }}</PORT-PROTOTYPE-REF>
                              {% set read_port = (swc.ports | selectattr("name", "equalto", read.port) | list | first) %}
                              <TARGET-DATA-PROTOTYPE-REF DEST="VARIABLE-DATA-PROTOTYPE">/{{ root_pkg }}/Interfaces/{{ read_port.interfaceRef if read_port else '' }}/{{ read.dataElement }}</TARGET-DATA-PROTOTYPE-REF>
                            </AUTOSAR-VARIABLE-IREF>
                          </ACCESSED-VARIABLE>
                        </VARIABLE-ACCESS>
                        {% endfor %}
                      </DATA-RECEIVE-POINT-BY-ARGUMENTS>
                      {% endif %}
                      {% if r.writes %}
                      <DATA-SEND-POINTS>
                        {% for write in r.writes %}
                        <VARIABLE-ACCESS>
                          <SHORT-NAME>DSP_{{ write.port }}_{{ write.dataElement }}</SHORT-NAME>
                          <ACCESSED-VARIABLE>
                            <AUTOSAR-VARIABLE-IREF>
                              <PORT-PROTOTYPE-REF DEST="P-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ swc.name }}/{{ write.port }}</PORT-PROTOTYPE-REF>
                              {% set write_port = (swc.ports | selectattr("name", "equalto", write.port) | list | first) %}
                              <TARGET-DATA-PROTOTYPE-REF DEST="VARIABLE-DATA-PROTOTYPE">/{{ root_pkg }}/Interfaces/{{ write_port.interfaceRef if write_port else '' }}/{{ write.dataElement }}</TARGET-DATA-PROTOTYPE-REF>
                            </AUTOSAR-VARIABLE-IREF>
                          </ACCESSED-VARIABLE>
                        </VARIABLE-ACCESS>
                        {% endfor %}
                      </DATA-SEND-POINTS>
                      {% endif %}
                      {% if r.calls %}
                      <SERVER-CALL-POINTS>
                        {% for call in r.calls %}
                        <SYNCHRONOUS-SERVER-CALL-POINT>
                          <SHORT-NAME>SCP_{{ call.port }}_{{ call.operation }}</SHORT-NAME>
                          {% set call_port = (swc.ports | selectattr("name", "equalto", call.port) | list | first) %}
                          <OPERATION-IREF>
                            <CONTEXT-R-PORT-REF DEST="R-PORT-PROTOTYPE">/{{ root_pkg }}/Components/{{ swc.name }}/{{ call.port }}</CONTEXT-R-PORT-REF>
                            <TARGET-REQUIRED-OPERATION-REF DEST="CLIENT-SERVER-OPERATION">/{{ root_pkg }}/Interfaces/{{ call_port.interfaceRef if call_port else '' }}/{{ call.operation }}</TARGET-REQUIRED-OPERATION-REF>
                          </OPERATION-IREF>
                        </SYNCHRONOUS-SERVER-CALL-POINT>
                        {% endfor %}
                      </SERVER-CALL-POINTS>
                      {% endif %}
                    </RUNNABLE-ENTITY>
                    {% endfor %}
                  </RUNNABLES>

                  <EVENTS>
                    {% for r in swc.runnables %}
                    {% if r.timingEventMs is not none %}
                    <TIMING-EVENT>
                      <SHORT-NAME>TE_{{ r.name }}</SHORT-NAME>
                      <START-ON-EVENT-REF DEST="RUNNABLE-ENTITY">/{{ root_pkg }}/Components/{{ swc.name }}/IB_{{ swc.name }}/{{ r.name }}</START-ON-EVENT-REF>
                      <PERIOD>{{ (r.timingEventMs / 1000.0) }}</PERIOD>
                    </TIMING-EVENT>
                    {% endif %}
                    {% for oie in r.operationInvokedEvents %}
                    <OPERATION-INVOKED-EVENT>
                      <SHORT-NAME>OIE_{{ r.name }}_{{ oie.port }}_{{ oie.operation }}</SHORT-NAME>
                      <START-ON-EVENT-REF DEST="RUNNABLE-ENTITY">/{{ root_pkg }}/Components/{{ swc.name }}/IB_{{ swc.name }}/{{ r.name }}</START-ON-EVENT-REF>
                    </OPERATION-INVOKED-EVENT>
                    {% endfor %}
                    {% endfor %}
                  </EVENTS>

                </SWC-INTERNAL-BEHAVIOR>
              </INTERNAL-BEHAVIORS>
            </APPLICATION-SW-COMPONENT-TYPE>
            {% endfor %}
          </ELEMENTS>
        </AR-PACKAGE>

        <AR-PACKAGE>
          <SHORT-NAME>System</SHORT-NAME>
          <ELEMENTS>
            <COMPOSITION-SW-COMPONENT-TYPE>
              <SHORT-NAME>{{ composition_name }}</SHORT-NAME>
              <COMPONENTS>
                {% for i in instances %}
                <SW-COMPONENT-PROTOTYPE>
                  <SHORT-NAME>{{ i.name }}</SHORT-NAME>
                  <TYPE-TREF DEST="APPLICATION-SW-COMPONENT-TYPE">/{{ root_pkg }}/Components/{{ i.typeRef }}</TYPE-TREF>
                </SW-COMPONENT-PROTOTYPE>
                {% endfor %}
              </COMPONENTS>
              <CONNECTORS>
                {% for c in connections %}
                <ASSEMBLY-SW-CONNECTOR>
                  <SHORT-NAME>{{ c.short_name }}</SHORT-NAME>
                  <PROVIDER-IREF>
                    <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/{{ root_pkg }}/System/{{ composition_name }}/{{ c.from_instance }}</CONTEXT-COMPONENT-REF>
                    <TARGET-P-PORT-REF DEST="P-PORT-PROTOTYPE">/{{ root_pkg }}/System/{{ composition_name }}/{{ c.from_instance }}/{{ c.from_port }}</TARGET-P-PORT-REF>
                  </PROVIDER-IREF>
                  <REQUESTER-IREF>
                    <CONTEXT-COMPONENT-REF DEST="SW-COMPONENT-PROTOTYPE">/{{ root_pkg }}/System/{{ composition_name }}/{{ c.to_instance }}</CONTEXT-COMPONENT-REF>
                    <TARGET-R-PORT-REF DEST="R-PORT-PROTOTYPE">/{{ root_pkg }}/System/{{ composition_name }}/{{ c.to_instance }}/{{ c.to_port }}</TARGET-R-PORT-REF>
                  </REQUESTER-IREF>
                </ASSEMBLY-SW-CONNECTOR>
                {% endfor %}
              </CONNECTORS>
            </COMPOSITION-SW-COMPONENT-TYPE>
            <SYSTEM>
              <SHORT-NAME>{{ system_name }}</SHORT-NAME>
              <ROOT-SOFTWARE-COMPOSITIONS>
                <ROOT-SW-COMPOSITION-PROTOTYPE>
                  <SHORT-NAME>RootComposition</SHORT-NAME>
                  <SOFTWARE-COMPOSITION-TREF DEST="COMPOSITION-SW-COMPONENT-TYPE">/{{ root_pkg }}/System/{{ composition_name }}</SOFTWARE-COMPOSITION-TREF>
                </ROOT-SW-COMPOSITION-PROTOTYPE>
              </ROOT-SOFTWARE-COMPOSITIONS>
            </SYSTEM>
          </ELEMENTS>
        </AR-PACKAGE>

      </AR-PACKAGES>
    </AR-PACKAGE>
  </AR-PACKAGES>
</AUTOSAR>
