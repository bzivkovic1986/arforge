{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "arforge compu methods schema",
  "type": "object",
  "required": [
    "compuMethods"
  ],
  "properties": {
    "compuMethods": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": [
              "name",
              "category",
              "unitRef",
              "factor",
              "offset"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "const": "linear"
              },
              "unitRef": {
                "type": "string",
                "minLength": 1
              },
              "factor": {
                "type": "number"
              },
              "offset": {
                "type": "number"
              },
              "physMin": {
                "type": "number"
              },
              "physMax": {
                "type": "number"
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": [
              "name",
              "category",
              "entries"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "category": {
                "const": "textTable"
              },
              "entries": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "value",
                    "label"
                  ],
                  "properties": {
                    "value": {
                      "type": "integer"
                    },
                    "label": {
                      "type": "string"
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
