{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "autosar-tool aggregator project schema (glob enabled)",
  "type": "object",
  "required": [
    "autosar",
    "inputs"
  ],
  "properties": {
    "autosar": {
      "type": "object",
      "required": [
        "version",
        "rootPackage"
      ],
      "properties": {
        "version": {
          "type": "string",
          "enum": [
            "4.2"
          ]
        },
        "rootPackage": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "inputs": {
      "type": "object",
      "required": [
        "interfaces",
        "swcs"
      ],
      "allOf": [
        {
          "anyOf": [
            {
              "required": [
                "datatypes"
              ]
            },
            {
              "required": [
                "baseTypes",
                "implementationDataTypes",
                "applicationDataTypes"
              ]
            }
          ]
        },
        {
          "anyOf": [
            {
              "required": [
                "system"
              ]
            },
            {
              "required": [
                "connections"
              ]
            }
          ]
        }
      ],
      "properties": {
        "datatypes": {
          "type": "string",
          "minLength": 1
        },
        "baseTypes": {
          "type": "string",
          "minLength": 1
        },
        "implementationDataTypes": {
          "type": "string",
          "minLength": 1
        },
        "applicationDataTypes": {
          "type": "string",
          "minLength": 1
        },
        "interfaces": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "swcs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "system": {
          "type": "string",
          "minLength": 1
        },
        "connections": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
