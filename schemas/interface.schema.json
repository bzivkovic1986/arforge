{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARForge Interface",
  "description": "Schema for sender-receiver, client-server, and mode-switch interface definitions.",
  "type": "object",
  "$defs": {
    "refName": {
      "type": "string",
      "minLength": 1
    },
    "descriptionProperty": {
      "type": "string",
      "description": "Optional human-readable documentation for this modeled object."
    },
    "dataElement": {
      "type": "object",
      "description": "Sender-receiver data element exposed by the interface.",
      "required": [
        "name",
        "typeRef"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/refName",
          "description": "Data element short name.",
          "examples": [
            "VehicleSpeed"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "typeRef": {
          "$ref": "#/$defs/refName",
          "description": "Application or implementation data type used by the data element.",
          "examples": [
            "App_VehicleSpeed"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "VehicleSpeed",
          "typeRef": "App_VehicleSpeed"
        }
      ]
    },
    "operationArgument": {
      "type": "object",
      "description": "Argument on a client-server operation.",
      "required": [
        "name",
        "direction",
        "typeRef"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/refName",
          "description": "Argument short name.",
          "examples": [
            "DtcId"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "direction": {
          "type": "string",
          "description": "Argument direction from the server implementation point of view.",
          "enum": [
            "in",
            "out",
            "inout"
          ],
          "examples": [
            "in"
          ]
        },
        "typeRef": {
          "$ref": "#/$defs/refName",
          "description": "Application or implementation data type used by the argument.",
          "examples": [
            "UInt16"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "DtcState",
          "direction": "out",
          "typeRef": "UInt8"
        }
      ]
    },
    "possibleError": {
      "type": "object",
      "description": "Possible client-server error entry.",
      "required": [
        "name",
        "code"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/refName",
          "description": "Application-visible error name.",
          "examples": [
            "DTC_NOT_FOUND"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "code": {
          "type": "integer",
          "description": "Numeric application error code.",
          "examples": [
            1
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "DTC_NOT_FOUND",
          "code": 1
        }
      ]
    },
    "operation": {
      "type": "object",
      "description": "Client-server operation signature.",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/refName",
          "description": "Operation short name.",
          "examples": [
            "ReadDTC"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "arguments": {
          "type": "array",
          "description": "Ordered list of operation arguments.",
          "items": {
            "$ref": "#/$defs/operationArgument"
          },
          "examples": [
            [
              {
                "name": "DtcId",
                "direction": "in",
                "typeRef": "UInt16"
              }
            ]
          ]
        },
        "returnType": {
          "description": "Return type name or the literal value 'void' for no return data.",
          "anyOf": [
            {
              "const": "void"
            },
            {
              "$ref": "#/$defs/refName"
            }
          ],
          "examples": [
            "UInt8",
            "void"
          ]
        },
        "possibleErrors": {
          "type": "array",
          "description": "Possible application errors raised by the operation.",
          "items": {
            "$ref": "#/$defs/possibleError"
          },
          "examples": [
            [
              {
                "name": "DTC_NOT_FOUND",
                "code": 1
              }
            ]
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "ReadDTC",
          "arguments": [
            {
              "name": "DtcId",
              "direction": "in",
              "typeRef": "UInt16"
            }
          ],
          "returnType": "UInt8",
          "possibleErrors": [
            {
              "name": "DTC_NOT_FOUND",
              "code": 1
            }
          ]
        }
      ]
    }
  },
  "required": [
    "interface"
  ],
  "properties": {
    "interface": {
      "type": "object",
      "description": "Single sender-receiver, client-server, or mode-switch interface.",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/refName",
          "description": "Interface short name.",
          "examples": [
            "If_Diagnostics"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "type": {
          "type": "string",
          "description": "Interface kind supported by ARForge.",
          "enum": [
            "senderReceiver",
            "clientServer",
            "modeSwitch"
          ],
          "examples": [
            "clientServer"
          ]
        },
        "modeGroupRef": {
          "$ref": "#/$defs/refName",
          "description": "Referenced ModeDeclarationGroup for a mode-switch interface.",
          "examples": [
            "Mdg_PowerState"
          ]
        },
        "dataElements": {
          "type": "array",
          "description": "Data elements for a sender-receiver interface.",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dataElement"
          }
        },
        "operations": {
          "type": "array",
          "description": "Operations for a client-server interface.",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/operation"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "senderReceiver"
              }
            }
          },
          "then": {
            "required": [
              "dataElements"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "operations"
                  ]
                },
                {
                  "required": [
                    "modeGroupRef"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "clientServer"
              }
            }
          },
          "then": {
            "required": [
              "operations"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "dataElements"
                  ]
                },
                {
                  "required": [
                    "modeGroupRef"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "modeSwitch"
              }
            }
          },
          "then": {
            "required": [
              "modeGroupRef"
            ],
            "not": {
              "anyOf": [
                {
                  "required": [
                    "dataElements"
                  ]
                },
                {
                  "required": [
                    "operations"
                  ]
                }
              ]
            }
          }
        }
      ],
      "additionalProperties": false,
      "examples": [
        {
          "name": "If_VehicleSpeed",
          "type": "senderReceiver",
          "dataElements": [
            {
              "name": "VehicleSpeed",
              "typeRef": "App_VehicleSpeed"
            }
          ]
        },
        {
          "name": "If_Diagnostics",
          "type": "clientServer",
          "operations": [
            {
              "name": "ReadDTC",
              "arguments": [
                {
                  "name": "DtcId",
                  "direction": "in",
                  "typeRef": "UInt16"
                }
              ],
              "returnType": "UInt8",
              "possibleErrors": [
                {
                  "name": "DTC_NOT_FOUND",
                  "code": 1
                }
              ]
            }
          ]
        },
        {
          "name": "If_PowerState",
          "type": "modeSwitch",
          "modeGroupRef": "Mdg_PowerState",
          "description": "Mode switch interface for ECU power state."
        }
      ]
    }
  },
  "additionalProperties": false
}
