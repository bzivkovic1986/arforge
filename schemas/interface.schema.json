{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "autosar-tool interface schema (SR + CS)",
  "type": "object",
  "required": [
    "interface"
  ],
  "properties": {
    "interface": {
      "type": "object",
      "required": [
        "name",
        "type"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "senderReceiver",
            "clientServer"
          ]
        },
        "dataElements": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name",
              "typeRef"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "typeRef": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "arguments": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "direction",
                    "typeRef"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "direction": {
                      "type": "string",
                      "enum": [
                        "in",
                        "out",
                        "inout"
                      ]
                    },
                    "typeRef": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "returnType": {
                "type": "string",
                "minLength": 1
              },
              "possibleErrors": {
                "type": "array",
                "items": {
                  "oneOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "object",
                      "required": [
                        "name",
                        "code"
                      ],
                      "properties": {
                        "name": {
                          "type": "string",
                          "minLength": 1
                        },
                        "code": {
                          "type": "integer"
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "senderReceiver"
              }
            }
          },
          "then": {
            "required": [
              "dataElements"
            ],
            "not": {
              "required": [
                "operations"
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "clientServer"
              }
            }
          },
          "then": {
            "required": [
              "operations"
            ],
            "not": {
              "required": [
                "dataElements"
              ]
            }
          }
        }
      ],
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
