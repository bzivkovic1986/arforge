{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "arforge implementation data types schema",
  "type": "object",
  "required": [
    "implementationDataTypes"
  ],
  "properties": {
    "implementationDataTypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "baseTypeRef"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "baseTypeRef": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
