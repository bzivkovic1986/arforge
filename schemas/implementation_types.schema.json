{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "arforge implementation data types schema",
  "type": "object",
  "required": [
    "implementationDataTypes"
  ],
  "properties": {
    "implementationDataTypes": {
      "type": "array",
      "items": {
        "allOf": [
          {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "kind": {
                "type": "string",
                "enum": [
                  "struct"
                ]
              },
              "baseTypeRef": {
                "type": "string",
                "minLength": 1
              },
              "fields": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "name",
                    "typeRef"
                  ],
                  "properties": {
                    "name": {
                      "type": "string",
                      "minLength": 1
                    },
                    "typeRef": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          },
          {
            "oneOf": [
              {
                "required": [
                  "baseTypeRef"
                ],
                "not": {
                  "required": [
                    "fields"
                  ]
                }
              },
              {
                "required": [
                  "fields"
                ]
              }
            ]
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
