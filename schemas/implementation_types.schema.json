{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARForge Implementation Data Types",
  "description": "Schema for scalar, struct, and array implementation data types.",
  "type": "object",
  "$defs": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "descriptionProperty": {
      "type": "string",
      "description": "Optional human-readable documentation for this modeled object."
    },
    "field": {
      "type": "object",
      "description": "Field in a struct implementation data type.",
      "required": [
        "name",
        "typeRef"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name",
          "description": "Struct field short name.",
          "examples": [
            "inner"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "typeRef": {
          "$ref": "#/$defs/name",
          "description": "Referenced implementation data type used by the field.",
          "examples": [
            "UInt16"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "quality",
          "typeRef": "UInt16"
        }
      ]
    },
    "scalarType": {
      "type": "object",
      "description": "Scalar implementation data type backed directly by a base type.",
      "required": [
        "name",
        "baseTypeRef"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name",
          "description": "Implementation data type short name.",
          "examples": [
            "UInt16"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "baseTypeRef": {
          "$ref": "#/$defs/name",
          "description": "Referenced base type name.",
          "examples": [
            "uint16"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "UInt16",
          "baseTypeRef": "uint16"
        }
      ]
    },
    "structType": {
      "type": "object",
      "description": "Struct implementation data type composed of named fields.",
      "required": [
        "name",
        "fields"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name",
          "description": "Implementation data type short name.",
          "examples": [
            "Impl_Outer"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "kind": {
          "type": "string",
          "description": "Explicit type kind for struct definitions. Optional for backward compatibility.",
          "enum": [
            "struct"
          ],
          "examples": [
            "struct"
          ]
        },
        "fields": {
          "type": "array",
          "description": "Ordered struct fields.",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/field"
          },
          "examples": [
            [
              {
                "name": "vehicle",
                "typeRef": "UInt16"
              },
              {
                "name": "wheel",
                "typeRef": "UInt16"
              }
            ]
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "Impl_Outer",
          "kind": "struct",
          "fields": [
            {
              "name": "inner",
              "typeRef": "Impl_Inner"
            },
            {
              "name": "quality",
              "typeRef": "UInt16"
            }
          ]
        }
      ]
    },
    "arrayType": {
      "type": "object",
      "description": "Array implementation data type with a fixed number of elements.",
      "required": [
        "name",
        "kind",
        "elementTypeRef",
        "length"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/name",
          "description": "Implementation data type short name.",
          "examples": [
            "Impl_WheelSpeeds"
          ]
        },
        "description": {
          "$ref": "#/$defs/descriptionProperty"
        },
        "kind": {
          "type": "string",
          "description": "Explicit type kind for array definitions.",
          "enum": [
            "array"
          ],
          "examples": [
            "array"
          ]
        },
        "elementTypeRef": {
          "$ref": "#/$defs/name",
          "description": "Referenced implementation data type used for each array element.",
          "examples": [
            "UInt16"
          ]
        },
        "length": {
          "type": "integer",
          "description": "Fixed number of array elements. Semantic validation enforces a positive value.",
          "examples": [
            4
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "Impl_WheelSpeeds",
          "kind": "array",
          "elementTypeRef": "UInt16",
          "length": 4
        }
      ]
    }
  },
  "required": [
    "implementationDataTypes"
  ],
  "properties": {
    "implementationDataTypes": {
      "type": "array",
      "description": "List of implementation data types used by interfaces and application data types.",
      "items": {
        "oneOf": [
          {
            "$ref": "#/$defs/scalarType"
          },
          {
            "$ref": "#/$defs/structType"
          },
          {
            "$ref": "#/$defs/arrayType"
          }
        ]
      },
      "examples": [
        [
          {
            "name": "UInt8",
            "baseTypeRef": "uint8"
          },
          {
            "name": "Impl_WheelSpeeds",
            "kind": "array",
            "elementTypeRef": "UInt16",
            "length": 4
          }
        ]
      ]
    }
  },
  "additionalProperties": false
}
