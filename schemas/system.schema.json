{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "arforge system schema (composition-based)",
  "type": "object",
  "required": [
    "system"
  ],
  "properties": {
    "system": {
      "type": "object",
      "required": [
        "name",
        "composition"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "composition": {
          "type": "object",
          "required": [
            "name",
            "components",
            "connectors"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "components": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "name",
                  "typeRef"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "typeRef": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              }
            },
            "connectors": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "required": [
                  "from",
                  "to"
                ],
                "properties": {
                  "from": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9_]+\\.[A-Za-z0-9_]+$"
                  },
                  "to": {
                    "type": "string",
                    "pattern": "^[A-Za-z0-9_]+\\.[A-Za-z0-9_]+$"
                  },
                  "dataElement": {
                    "type": "string",
                    "minLength": 1
                  },
                  "operation": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
