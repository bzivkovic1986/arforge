{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "arforge system schema (instance-based)",
  "type": "object",
  "required": [
    "system"
  ],
  "properties": {
    "system": {
      "type": "object",
      "required": [
        "name",
        "instances",
        "connections"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "instances": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name",
              "typeRef"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "typeRef": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "connections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "from",
              "to"
            ],
            "properties": {
              "from": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_]+\\.[A-Za-z0-9_]+$"
              },
              "to": {
                "type": "string",
                "pattern": "^[A-Za-z0-9_]+\\.[A-Za-z0-9_]+$"
              },
              "dataElement": {
                "type": "string",
                "minLength": 1
              },
              "operation": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
