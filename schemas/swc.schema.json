{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "autosar-tool SWC schema",
  "type": "object",
  "required": [
    "swc"
  ],
  "properties": {
    "swc": {
      "type": "object",
      "required": [
        "name",
        "runnables",
        "ports"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "runnables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "timingEventMs": {
                "type": "integer",
                "minimum": 1
              },
              "reads": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "port",
                    "dataElement"
                  ],
                  "properties": {
                    "port": {
                      "type": "string",
                      "minLength": 1
                    },
                    "dataElement": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "writes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "port",
                    "dataElement"
                  ],
                  "properties": {
                    "port": {
                      "type": "string",
                      "minLength": 1
                    },
                    "dataElement": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "calls": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "port",
                    "operation"
                  ],
                  "properties": {
                    "port": {
                      "type": "string",
                      "minLength": 1
                    },
                    "operation": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              },
              "operationInvokedEvents": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "port",
                    "operation"
                  ],
                  "properties": {
                    "port": {
                      "type": "string",
                      "minLength": 1
                    },
                    "operation": {
                      "type": "string",
                      "minLength": 1
                    }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": false
          }
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name",
              "direction",
              "interfaceRef"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "direction": {
                "type": "string",
                "enum": [
                  "provides",
                  "requires"
                ]
              },
              "interfaceRef": {
                "type": "string",
                "minLength": 1
              },
              "comSpec": {
                "type": "object",
                "properties": {
                  "mode": {
                    "type": "string",
                    "enum": [
                      "implicit",
                      "explicit",
                      "queued"
                    ]
                  },
                  "queueLength": {
                    "type": "integer"
                  },
                  "callMode": {
                    "type": "string",
                    "enum": [
                      "synchronous",
                      "asynchronous"
                    ]
                  },
                  "timeoutMs": {
                    "type": "integer",
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
