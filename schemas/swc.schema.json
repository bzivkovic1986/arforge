{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "autosar-tool SWC schema",
  "type": "object",
  "required": [
    "swc"
  ],
  "properties": {
    "swc": {
      "type": "object",
      "required": [
        "name",
        "runnables",
        "ports"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "runnables": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name",
              "timingEventMs"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "timingEventMs": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        },
        "ports": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "name",
              "direction",
              "interfaceRef"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "direction": {
                "type": "string",
                "enum": [
                  "provides",
                  "requires"
                ]
              },
              "interfaceRef": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}