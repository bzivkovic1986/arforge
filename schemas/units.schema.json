{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ARForge Units",
  "description": "Schema for physical units referenced by application data types and compu methods.",
  "type": "object",
  "$defs": {
    "unit": {
      "type": "object",
      "description": "Physical unit definition.",
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "description": "Unit short name used by references in the model.",
          "minLength": 1,
          "examples": [
            "km_h"
          ]
        },
        "displayName": {
          "type": "string",
          "description": "Human-readable display text for the unit.",
          "minLength": 1,
          "examples": [
            "km/h"
          ]
        }
      },
      "additionalProperties": false,
      "examples": [
        {
          "name": "km_h",
          "displayName": "km/h"
        }
      ]
    }
  },
  "required": [
    "units"
  ],
  "properties": {
    "units": {
      "type": "array",
      "description": "List of unit definitions.",
      "items": {
        "$ref": "#/$defs/unit"
      },
      "examples": [
        [
          {
            "name": "km_h",
            "displayName": "km/h"
          }
        ]
      ]
    }
  },
  "additionalProperties": false
}
