{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "autosar-tool datatypes schema",
  "type": "object",
  "required": [
    "datatypes"
  ],
  "properties": {
    "datatypes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "category"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "category": {
            "type": "string",
            "enum": [
              "implementation"
            ]
          },
          "baseType": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}